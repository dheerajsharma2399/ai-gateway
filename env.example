# ─────────────────────────────────────────────────────────────────────────────
# AI Gateway — Environment Variables (Tailscale-only setup)
# Copy to .env and fill real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ────────────────────────────────────────────────────────────────────
OPENCHAMBER_DOMAIN=opencode.mooh.me
CLAUDEUI_DOMAIN=claude.mooh.me

# ── LiteLLM gateway (required) ────────────────────────────────────────────────
LITELLM_BASE_URL=http://litellm-proxy:4000
LITELLM_MASTER_KEY=<your-litellm-master-key>
LITELLM_API_KEY=<your-litellm-virtual-key>

# ── 9router runtime (optional, enabled by default) ───────────────────────────
# Persistent auth/settings are loaded from mounted folder: /home/ubuntu/agents/9router
NINE_ROUTER_ENABLED=true
NINE_ROUTER_PORT=20128

# ── OpenCode model (optional override) ───────────────────────────────────────
OPENCODE_DEFAULT_MODEL=drdash/anthropic/claude-3.5-sonnet

# ── GitHub MCP (optional) ─────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Git identity (optional) ───────────────────────────────────────────────────
GIT_USER_NAME=AI Agent
GIT_USER_EMAIL=agent@localhost

# ── UI auth and timezone (optional) ───────────────────────────────────────────
UI_PASSWORD=
TZ=Asia/Kolkata
